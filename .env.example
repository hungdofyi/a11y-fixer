# ===========================================
# a11y-fixer Environment Configuration
# ===========================================
# Copy to .env and fill in your values

# --- API Server ---
PORT=3001
A11Y_API_KEY=your-api-key-here          # For CLI/programmatic access
A11Y_DB_PATH=./data/a11y-fixer.db       # SQLite database path
A11Y_WORKSPACE_ROOT=.                    # Allowed root for static file scanning

# --- Google OAuth SSO (Dashboard) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
ALLOWED_DOMAIN=yourcompany.com           # Restrict to Google Workspace domain
BASE_URL=http://localhost:3001           # Public URL (for OAuth callback)

# --- Session ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate-a-64-char-hex-string-here

# --- Claude AI Engine (Optional) ---
CLAUDE_CODE_OAUTH_TOKEN=                 # OAuth token for Claude API
ANTHROPIC_API_KEY=                       # Or use API key directly

{
  "name": "a11y-fixer",
  "version": "0.1.0",
  "private": true,
  "description": "Accessibility scanning, fixing, and VPAT reporting monorepo",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "a11y": "node apps/cli/bin/run.js",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "typecheck": "turbo typecheck"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<10.2.1": ">=10.2.1",
      "esbuild@<=0.24.2": ">=0.25.0"
    }
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "prettier": "^3.4.0"
  }
}
